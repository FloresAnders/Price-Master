{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "instructions": ["AGENTS.md"],
  "model": "big-pickle",
  "provider": {
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    }
  },
  "agent": {
    "explore": {
      "description": "Fast agent for exploring codebases",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "general": {
      "description": "General-purpose subagent for complex tasks",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "architecture": {
      "description": "Architecture analysis agent",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "dependency": {
      "description": "Dependency management agent",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "refactor": {
      "description": "Code refactoring agent",
      "mode": "subagent",
      "model": "openai/gpt-5-codex"
    },
    "testing": {
      "description": "Testing agent",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "manager": {
      "description": "Main orchestrating agent",
      "mode": "subagent",
      "model": "big-pickle"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--browser", "msedge"],
      "enabled": true
    }
  }
}
