rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.role == 'admin' || request.auth.token.role == 'superadmin');
    }

    // Colección de emails - solo escritura desde el cliente, lectura y actualización desde Functions
    match /emails/{emailId} {
      // Permitir crear documentos desde el cliente
      allow create: if request.auth != null;
      
      // Solo Functions puede actualizar el estado
      allow update: if false;
      
      // Solo lectura para administradores
      allow read: if request.auth != null && request.auth.token.role == 'admin';
    }

    match /closingTimeExtensions/{extensionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        (request.resource.data.status == 'pending' || isAdmin());
      allow update: if isAdmin() ||
        (
          isSignedIn() &&
          (resource.data.status == 'pending' ||
            resource.data.status == 'rejected' ||
            resource.data.status == 'expired') &&
          request.resource.data.status == 'pending' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'company',
              'companyKey',
              'operationalDateKey',
              'turno',
              'extraMinutes',
              'status',
              'reason',
              'requestedBy',
              'createdAt',
              'updatedAt'
            ])
        ) ||
        (
          isSignedIn() &&
          (resource.data.status == 'approved' ||
            resource.data.status == 'rejected') &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['responseSeenAt'])
        ) ||
        (
          isSignedIn() &&
          resource.data.status == 'approved' &&
          request.resource.data.status == 'used' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'usedBy', 'usedAt'])
        );
      allow delete: if isAdmin();
    }

    match /pendingInvoiceDeletionRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        (request.resource.data.status == 'pending' || isAdmin());
      allow update: if isAdmin() ||
        (
          isSignedIn() &&
          resource.data.status == 'rejected' &&
          request.resource.data.status == 'pending' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'company',
              'companyKey',
              'invoiceId',
              'invoiceNumber',
              'invoiceDocType',
              'paymentStatus',
              'amount',
              'currency',
              'providerCode',
              'manager',
              'status',
              'reason',
              'requestedBy',
              'createdAt',
              'updatedAt',
              'approvedBy',
              'approvedAt',
              'rejectedBy',
              'rejectedAt',
              'rejectionReason',
              'responseSeenAt'
            ])
        ) ||
        (
          isSignedIn() &&
          (resource.data.status == 'approved' ||
            resource.data.status == 'rejected') &&
          (resource.data.requestedBy == request.auth.token.email ||
            resource.data.requestedBy == request.auth.uid) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['responseSeenAt'])
        );
      allow delete: if isAdmin();
    }

    match /Facturas/{empresaId}/movements/{movementId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    function isRegistroTucanRecord() {
      return request.resource.data.keys().hasOnly([
          'empresaId',
          'empresa',
          'dateKey',
          'fecha',
          'hora',
          'saldoPaginaTucan',
          'saldoFondoTucan',
          'pagosHoy',
          'saldoSinpesRecibidos',
          'total',
          'motivo',
          'currency',
          'createdById',
          'createdByName',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.keys().hasAll([
          'empresaId',
          'empresa',
          'dateKey',
          'fecha',
          'hora',
          'saldoPaginaTucan',
          'saldoFondoTucan',
          'pagosHoy',
          'saldoSinpesRecibidos',
          'total',
          'currency',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.empresa is string &&
        request.resource.data.dateKey is number &&
        request.resource.data.fecha is string &&
        request.resource.data.hora is string &&
        request.resource.data.saldoPaginaTucan is number &&
        request.resource.data.saldoFondoTucan is number &&
        request.resource.data.pagosHoy is number &&
        request.resource.data.saldoSinpesRecibidos is number &&
        request.resource.data.total is number &&
        request.resource.data.currency == 'CRC' &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        (!request.resource.data.keys().hasAny(['motivo']) ||
          request.resource.data.motivo is string) &&
        (!request.resource.data.keys().hasAny(['empresaId']) ||
          request.resource.data.empresaId is string) &&
        (!request.resource.data.keys().hasAny(['createdById']) ||
          request.resource.data.createdById is string) &&
        (!request.resource.data.keys().hasAny(['createdByName']) ||
          request.resource.data.createdByName is string);
    }

    match /registrotucan/{empresaId}/records/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        isRegistroTucanRecord() &&
        request.resource.data.empresaId == empresaId;
      allow update, delete: if isAdmin();
    }

    match /proveedores/{empresaId} {
      allow read, write: if isSignedIn();

      match /items/{providerCode} {
        allow read, write: if isSignedIn();
      }
    }

    function internalDebtUserPartyKey() {
      return 'user:' + request.auth.uid;
    }

    function isInternalDebtParticipant(data) {
      return isSignedIn() &&
        data.participantIds is list &&
        internalDebtUserPartyKey() in data.participantIds;
    }

    function hasInternalDebtsPermission() {
      return isSignedIn() &&
        (
          isAdmin() ||
          get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.permissions.deudasInternas == true ||
          request.auth.token.deudasInternas == true ||
          (
            request.auth.token.permissions is map &&
            request.auth.token.permissions.deudasInternas == true
          )
        );
    }

    function hasInternalDebtBaseShape(data) {
      return data.keys().hasAll([
          'ownerId',
          'debtor',
          'creditor',
          'participantIds',
          'amountOriginal',
          'balance',
          'reason',
          'date',
          'status',
          'movements',
          'createdAt',
          'updatedAt',
          'createdById',
          'createdByName'
        ]) &&
        data.ownerId is string &&
        data.debtor is map &&
        data.creditor is map &&
        data.participantIds is list &&
        data.amountOriginal is number &&
        data.balance is number &&
        data.reason is string &&
        data.date is string &&
        (data.status == 'open' || data.status == 'paid') &&
        data.movements is list &&
        data.createdById == request.auth.uid;
    }

    match /internalDebts/{debtId} {
      allow read: if hasInternalDebtsPermission() &&
        isInternalDebtParticipant(resource.data);
      allow create: if hasInternalDebtsPermission() &&
        hasInternalDebtBaseShape(request.resource.data) &&
        isInternalDebtParticipant(request.resource.data);
      allow update: if hasInternalDebtsPermission() &&
        isInternalDebtParticipant(resource.data) &&
        resource.data.status != 'paid' &&
        resource.data.balance > 0 &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.debtor == resource.data.debtor &&
        request.resource.data.creditor == resource.data.creditor &&
        request.resource.data.participantIds == resource.data.participantIds &&
        request.resource.data.amountOriginal == resource.data.amountOriginal &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.createdById == resource.data.createdById &&
        request.resource.data.movements.size() == resource.data.movements.size() + 1 &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['balance', 'status', 'movements', 'updatedAt']);
      allow delete: if isAdmin();
    }
    
    // Otras reglas existentes...
    match /{collection}/{document=**} {
      allow read, write: if request.auth != null &&
        collection != 'registrotucan' &&
        collection != 'pendingInvoiceDeletionRequests' &&
        collection != 'Facturas' &&
        collection != 'internalDebts';
    }
  }
}
