rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Colección de emails - solo escritura desde el cliente, lectura y actualización desde Functions
    match /emails/{emailId} {
      // Permitir crear documentos desde el cliente
      allow create: if request.auth != null;
      
      // Solo Functions puede actualizar el estado
      allow update: if false;
      
      // Solo lectura para administradores
      allow read: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    // Taskboard - Tableros de tareas
    match /taskboardWorkspaces/{ownerId} {
      allow read, write: if request.auth != null;
      
      match /boards/{boardId} {
        allow read, write: if request.auth != null;
        
        match /columns/{columnId} {
          allow read, write: if request.auth != null;
        }
        
        match /cards/{cardId} {
          allow read, write: if request.auth != null;
          
          match /checklist/{itemId} {
            allow read, write: if request.auth != null;
          }
          
          match /comments/{commentId} {
            allow read, write: if request.auth != null;
          }
          
          match /attachments/{attachmentId} {
            allow read, write: if request.auth != null;
          }
          
          match /activity/{activityId} {
            allow read, write: if request.auth != null;
          }
        }
      }
    }
    
    // Otras reglas existentes...
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
